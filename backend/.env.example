# ── Database ─────────────────────────────────────────────────────
# SQLite (development / local)
DATABASE_URL="file:./dev.db"
# PostgreSQL (recommended for production on Railway)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ── Authentication ───────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change_me_to_a_long_random_string_at_least_32_chars"

# ── Groq AI ──────────────────────────────────────────────────────
# Get your API key at https://console.groq.com
GROQ_API_KEY="your_groq_api_key_here"
GROQ_MODEL="llama-3.1-8b-instant"
# Vision model for photo-based calorie analysis (optional)
GROQ_VISION_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# ── Server ───────────────────────────────────────────────────────
PORT=4000
# Set to your frontend production URL (no trailing slash)
# Comma-separate multiple origins if needed
CLIENT_URL="http://localhost:5173"

# ── Email / Password Reset ───────────────────────────────────────
# Required to send password-reset emails.
# For Gmail: enable 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords and use the 16-char password as SMTP_PASS.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your_gmail_address@gmail.com"
SMTP_PASS="your_gmail_app_password"
SMTP_FROM="FitAI Coach <your_gmail_address@gmail.com>"
